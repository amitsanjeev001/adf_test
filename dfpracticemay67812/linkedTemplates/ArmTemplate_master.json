{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "dfpracticemay67812"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"AzureSqlmaydb_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlmaydb'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsmay.dfs.core.windows.net/"
		},
		"AzureKeyVault1_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://maykeyvault5657.vault.azure.net/"
		},
		"AzureSqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "maydbserver.database.windows.net"
		},
		"AzureSqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "master"
		},
		"AzureSqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sanjeev"
		},
		"AzureSqlmaydb_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "maydbserver.database.windows.net"
		},
		"AzureSqlmaydb_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "maydb"
		},
		"AzureSqlmaydb_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sanjeev"
		},
		"RestServiceJSONPlaceholder REST API_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://reqres.in"
		},
		"RestServicejsonplaceholder_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://jsonplaceholder.typicode.com"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "dfpracticemay67812_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"AzureSqlmaydb_password": {
						"value": "[parameters('AzureSqlmaydb_password')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"AzureKeyVault1_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault1_properties_typeProperties_baseUrl')]"
					},
					"AzureSqlmaydb_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlmaydb_properties_typeProperties_server')]"
					},
					"AzureSqlmaydb_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlmaydb_properties_typeProperties_database')]"
					},
					"AzureSqlmaydb_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlmaydb_properties_typeProperties_userName')]"
					},
					"RestServiceJSONPlaceholder REST API_properties_typeProperties_url": {
						"value": "[parameters('RestServiceJSONPlaceholder REST API_properties_typeProperties_url')]"
					},
					"RestServicejsonplaceholder_properties_typeProperties_url": {
						"value": "[parameters('RestServicejsonplaceholder_properties_typeProperties_url')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "dfpracticemay67812_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'dfpracticemay67812_ArmTemplate_0')]"
			]
		}
	]
}